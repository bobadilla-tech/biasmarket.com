{
  "name": "biasmarket",
  "version": "1.0.0",
  "description": "A store builder for fandom sellers who already sell but struggle with messy, manual workflows, organize orders, manage reservations, and keep the human touch.",
  "author": "Bobadilla Technologie",
  "scripts": {
    "test": "turbo run test",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "docker:dev": "docker compose -f infra/docker/docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f infra/docker/docker-compose.dev.yml down",
    "docker:prod": "docker compose -f infra/docker/docker-compose.yml up -d --build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.10",
    "turbo": "^2.10.5"
  }
}
