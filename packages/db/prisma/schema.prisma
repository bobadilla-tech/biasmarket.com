generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String?
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String    @default("seller")
  locale        String    @default("es")
  createdAt     DateTime
  updatedAt     DateTime

  sessions       Session[]
  accounts       Account[]
  stores         Store[]
  reviewedProofs PaymentProof[]

  @@map("user")
}

model Store {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  locale              String   @default("es")
  ownerId             String
  themeConfig         Json
  logoUrl             String?
  paymentInstructions String
  whatsappNumber      String?
  defaultCurrency     String   @default("PEN")
  holdWindowHours     Int      @default(48)
  createdAt           DateTime @default(now())

  owner           User                   @relation(fields: [ownerId], references: [id])
  products        Product[]
  orders          Order[]
  categories      Category[]
  collections     Collection[]
  sections        StoreSection[]
  customers       Customer[]
  paymentMethods  PaymentMethodConfig[]
  deliveryMethods DeliveryMethodConfig[]

  @@index([ownerId])
}

model Product {
  id          String        @id @default(cuid())
  storeId     String
  name        String
  description String        @default("")
  price       Decimal       @db.Decimal(10, 2)
  currency    String        @default("PEN")
  images      String[]      @default([])
  availableUntil DateTime?
  status      ProductStatus @default(DRAFT)
  soldOut     Boolean       @default(false)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())

  store       Store               @relation(fields: [storeId], references: [id])
  variants    ProductVariant[]
  orderItems  OrderItem[]
  categories  ProductCategory[]
  collections CollectionProduct[]

  @@index([storeId])
  @@index([storeId, status])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  storeId       String
  name          String
  stock         Int?
  reserved      Int      @default(0)
  priceOverride Decimal? @db.Decimal(10, 2)
  imageOverride String?
  attributes    Json     @default("{}")

  product    Product     @relation(fields: [productId], references: [id])
  orderItems OrderItem[]

  @@index([productId])
  @@index([storeId])
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

model Category {
  id        String   @id @default(cuid())
  storeId   String
  parentId  String?
  name      String
  createdAt DateTime @default(now())

  store    Store             @relation(fields: [storeId], references: [id])
  parent   Category?         @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[]        @relation("CategoryTree")
  products ProductCategory[]

  @@unique([storeId, parentId, name])
  @@index([storeId])
  @@index([parentId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([productId, categoryId])
  @@index([categoryId])
}

model Collection {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String   @default("")
  createdAt   DateTime @default(now())

  store    Store               @relation(fields: [storeId], references: [id])
  products CollectionProduct[]
  sections StoreSection[]

  @@unique([storeId, slug])
  @@index([storeId])
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int

  collection Collection @relation(fields: [collectionId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@id([collectionId, productId])
  @@index([productId])
}

enum StoreSectionType {
  COLLECTION
  BANNER
  TEXT_BLOCK
}

model StoreSection {
  id           String           @id @default(cuid())
  storeId      String
  type         StoreSectionType
  collectionId String?
  content      Json             @default("{}")
  position     Int
  createdAt    DateTime         @default(now())

  store      Store       @relation(fields: [storeId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id])

  @@index([storeId])
  @@index([storeId, position])
}

model Order {
  id                 String             @id @default(cuid())
  storeId            String
  customerId         String?
  customerEmail      String?
  customerPhone      String
  customerName       String?
  deliveryMethodType DeliveryMethodType
  deliveryDetails    Json
  paymentStatus      PaymentStatus      @default(PENDING_PAYMENT)
  fulfillmentStatus  FulfillmentStatus  @default(ORDERING)
  totalAmount        Decimal            @db.Decimal(10, 2)
  requiredAmount     Decimal            @db.Decimal(10, 2)
  currency           String
  expiresAt          DateTime
  createdAt          DateTime           @default(now())

  store    Store          @relation(fields: [storeId], references: [id])
  customer Customer?      @relation(fields: [customerId], references: [id])
  items    OrderItem[]
  proofs   PaymentProof[]

  @@index([storeId, paymentStatus])
  @@index([storeId, createdAt])
  @@index([paymentStatus, expiresAt])
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  storeId             String
  productId           String
  variantId           String?
  quantity            Int
  unitPriceAtPurchase Decimal  @db.Decimal(10, 2)
  currency            String
  createdAt           DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([storeId])
}

model PaymentProof {
  id          String      @id @default(cuid())
  orderId     String
  storeId     String
  imageUrl    String
  status      ProofStatus @default(PENDING_REVIEW)
  submittedAt DateTime    @default(now())
  reviewedBy  String?
  reviewedAt  DateTime?

  order    Order @relation(fields: [orderId], references: [id])
  reviewer User? @relation(fields: [reviewedBy], references: [id])

  @@index([orderId])
  @@index([storeId, status])
}

enum PaymentStatus {
  PENDING_PAYMENT
  PAYMENT_SUBMITTED
  VERIFIED
  REJECTED
  CANCELLED
}

enum FulfillmentStatus {
  ORDERING
  IN_TRANSIT
  READY
  COMPLETED
}

enum ProofStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum DeliveryMethodType {
  PICKUP
  COURIER
}

model PaymentMethodConfig {
  id                    String   @id @default(cuid())
  storeId               String
  method                String
  enabled               Boolean  @default(true)
  details               Json
  depositPercentPickup  Int      @default(100)
  depositPercentCourier Int      @default(100)
  createdAt             DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, method])
  @@index([storeId])
}

model DeliveryMethodConfig {
  id        String             @id @default(cuid())
  storeId   String
  type      DeliveryMethodType
  enabled   Boolean            @default(true)
  details   Json
  createdAt DateTime           @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, type])
  @@index([storeId])
}

model Customer {
  id           String   @id @default(cuid())
  storeId      String
  phone        String
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  store  Store   @relation(fields: [storeId], references: [id])
  orders Order[]

  @@unique([storeId, phone])
  @@index([storeId])
}

enum InquiryStatus {
  NEW
  REVIEWED
  ARCHIVED
}

// Platform-level sales inbox — not tenant data, no storeId by design.
model ContactInquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  company     String?
  inquiryType String?
  message     String
  status      InquiryStatus @default(NEW)
  createdAt   DateTime      @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  storeId    String
  action     String
  entityType String
  entityId   String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([entityType, entityId])
}

//BETHER AUTH

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}
