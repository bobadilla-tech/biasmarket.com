# ============================================================================
# biasmarket-app — Docker environment defaults
# ============================================================================
# Committed with SAFE, WORKING DEV DEFAULTS. Powers the full dev stack out of
# the box (docker-compose.dev.yml loads it directly via env_file).
#
# For production, copy to `.env` (gitignored) in this same directory and
# replace every value with a real secret:
#   cp .env.example .env
#
# Optional `.env.local` (gitignored, dev-only) may sit alongside this file to
# override any value for personal per-developer tweaks. Layered on top of
# this file in docker-compose.dev.yml; not required to exist.
# ============================================================================

COMPOSE_BAKE=true

# ---- PostgreSQL (packages/db, apps/api) ----------------------------------
# Inside the Docker network, containers reach Postgres via the compose
# service name "db", not "localhost". Port still published to the host so
# host-side tools (psql, prisma studio run natively) can connect via
# localhost as before.
POSTGRES_USER=biasmarket
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=biasmarket
DATABASE_URL=postgresql://biasmarket:localdevpassword@db:5432/biasmarket

# ---- apps/api (NestJS + better-auth) --------------------------------------
PORT=3000
# Prod: https://api.biasmarket.com (own subdomain, see infra/caddy/Caddyfile)
BETTER_AUTH_URL=http://localhost:3000
# Freshly generated dev-only secret — never reuse the old value that used to
# live in apps/api/.env, and rotate again before any real deployment.
BETTER_AUTH_SECRET=848fc28be743f718af16aebd093306bf87898671ad686db26b19973b04ada24b
# Prod: https://biasmarket.com — used for CORS and the GET / redirect target
WEB_URL=http://localhost:3001

# ---- apps/web (Next.js) ----------------------------------------------------
# Must be reachable from the BROWSER — published host port, never the
# internal docker hostname "api:3000". Prod: https://api.biasmarket.com
# (no /api suffix — the app appends that itself).
NEXT_PUBLIC_API_URL=http://localhost:3000
# Server-side (SSR/Server Component) fetches run inside the "web" container,
# where "localhost" refers to that container, not "api". Use the compose
# service name instead. Not needed in prod — NEXT_PUBLIC_API_URL there is
# already a real, container-reachable domain.
INTERNAL_API_URL=http://api:3000

# Prod: S3_ENDPOINT stays the internal Docker network name (the minio
# service in docker-compose.yml) — never a public URL.
S3_ENDPOINT=http://minio:9000
# Prod: https://cdn.biasmarket.com (see infra/caddy/Caddyfile) — the value
# returned to clients gets saved verbatim into Product.images/Store.logoUrl,
# so treat it as durable once real uploads exist.
S3_PUBLIC_URL=http://localhost:9000
# Prod: rotated by `pnpm env:init --prod` (scripts/init-env.ts) — never reuse
# these dev-only defaults, they double as the MinIO root credentials in
# docker-compose.yml.
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET=products
